# Server
PORT=3000
APP_AUTH_TOKEN=change-me
CORS_ORIGIN=*

# LLM
LLM_PROVIDER=deepseek
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_MS=15000
LLM_MAX_RETRIES=1
LLM_MAX_INPUT_CHARS=1000
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=800
LLM_DAILY_LIMIT=1000

# Video / ASR
UPLOAD_DIR=/app/data/uploads
VIDEO_MAX_UPLOAD_MB=300
VIDEO_FRAME_COUNT=4
VIDEO_FRAME_WIDTH=1280
ASR_PROVIDER=openai-compatible
ASR_API_BASE=https://api.openai.com/v1
ASR_API_KEY=sk-xxxxxxxxxxxxxxxx
ASR_MODEL=whisper-1
ASR_TIMEOUT_MS=300000
ASR_MAX_RETRIES=1

# Database
DB_PATH=/app/data/express.db
BACKUP_CRON=0 2 * * *
BACKUP_DIR=/app/backups
